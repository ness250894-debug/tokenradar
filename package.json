{
  "name": "tokenradar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['out','.next']) fs.rmSync(p,{recursive:true,force:true});\"",
    "consolidate": "tsx scripts/consolidate-data.ts",
    "prebuild": "tsx scripts/validate-env.ts && npm run consolidate && tsx scripts/validate-content.ts && tsx scripts/generate-og-images.tsx && tsx scripts/generate-sitemap.ts",
    "build": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "studio": "remotion studio src/video/Root.tsx"
  },
  "dependencies": {
    "@coingecko/coingecko-typescript": "^3.1.5",
    "@remotion/cli": "^4.0.446",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@xdevplatform/xdk": "^0.5.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "grammy": "^1.42.0",
    "isomorphic-dompurify": "^3.7.1",
    "lucide-react": "^1.8.0",
    "marked": "^17.0.4",
    "next": "^16.2.1",
    "next-nprogress-bar": "^2.4.7",
    "postcss": "^8.5.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remotion": "^4.0.446",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-formatter-unix": "^9.0.1",
    "satori": "^0.26.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "wrangler": "^4.83.0"
  }
}
