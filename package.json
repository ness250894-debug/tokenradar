{
  "name": "tokenradar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "npx rimraf out .next",
    "consolidate": "npx tsx scripts/consolidate-data.ts",
    "prebuild": "npx tsx scripts/validate-env.ts && npm run consolidate && npx tsx scripts/validate-content.ts && npx tsx scripts/generate-sitemap.ts",
    "build": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next build",
    "build:cf": "npm run build && npx opennextjs-cloudflare build",
    "deploy:prep": "shx rm -rf .open-next/assets/data .open-next/assets/content && shx cp -r data .open-next/assets/data && shx cp -r content .open-next/assets/content",
    "deploy": "npm run build:cf && npm run deploy:prep && npx wrangler pages deploy .open-next/assets --project-name tokenradar --commit-dirty=true",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "studio": "remotion studio src/video/Root.tsx"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.18.0",
    "@coingecko/coingecko-typescript": "^3.1.5",
    "@google/generative-ai": "^0.24.1",
    "@remotion/cli": "^4.0.446",
    "@xdevplatform/xdk": "^0.5.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "grammy": "^1.42.0",
    "isomorphic-dompurify": "^3.7.1",
    "lucide-react": "^1.8.0",
    "marked": "^17.0.4",
    "mastra": "^1.6.0",
    "next": "^16.2.1",
    "next-nprogress-bar": "^2.4.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remotion": "^4.0.446",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-formatter-unix": "^9.0.1",
    "shx": "^0.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "wrangler": "^4.83.0"
  }
}
