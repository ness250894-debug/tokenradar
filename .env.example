# ============================================
# TokenRadar.co — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.

# CoinGecko (optional — free tier works without key)
COINGECKO_API_KEY=

# Claude AI — Required for content generation
ANTHROPIC_API_KEY=

# Gemini AI — Used for social summaries (Free tier)
GEMINI_API_KEY=
# Social Media — X (Twitter) OAuth 2.0 — run `npx tsx scripts/generate-x-token.ts` to obtain
X_OAUTH2_CLIENT_ID=
X_OAUTH2_CLIENT_SECRET=
X_OAUTH2_REFRESH_TOKEN=
X_BEARER_TOKEN=

# Social Media — Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Deployment — Cloudflare Pages
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# Error Reporting & Monitoring — Telegram (separate bot for ops alerts)
TELEGRAM_REPORT_BOT_TOKEN=
TELEGRAM_REPORT_CHAT_ID=


# Public — Exposed to browser
NEXT_PUBLIC_SITE_URL=https://tokenradar.co
NEXT_PUBLIC_SITE_NAME=TokenRadar

# Social Media — Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# GA4
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Social Media — YouTube Shorts Automation
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=