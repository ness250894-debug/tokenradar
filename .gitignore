# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/.open-next/

# production
/build
/dist-cloudflare/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
build.log

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local cache
/src/data/cache/

# dev scratch files
test-*.ts
!tests/**

# AI content pipeline
*.prompt.txt
data/latest-batch-alert.txt
# X OAuth 2.0 Persistence (Required for rotating tokens in CI/CD)
